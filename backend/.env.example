# Copy to `backend/.env` and set a real connection string. Postgres must be running.
# Browse data: `npm run db:studio` from repo root, or `cd backend && npm run prisma:studio`,
# or `npx prisma studio` from root (uses root prisma.config.ts → backend).
DATABASE_URL="postgresql://DB_USER:DB_PASSWORD@localhost:5432/DB_NAME?schema=public"
PORT=4000
# CORS is open to all origins in app.ts for local hackathon demos (Vite port may change). Kept for optional future use.
FRONTEND_ORIGINS="http://localhost:5173,http://localhost:3000"
OTP_MOCK_CODE="1234"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
